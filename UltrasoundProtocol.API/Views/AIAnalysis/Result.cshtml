@{
    ViewData["Title"] = "AI Tahlil Natijasi";
    bool success = ViewBag.Success == true;
    string? analysis = ViewBag.Analysis;
    string? error = ViewBag.Error;
    string? bodyPart = ViewBag.BodyPart;
}

@functions {
    static string FormatMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        var sb = new System.Text.StringBuilder();
        sb.Append("<div class='ai-content'>");
        foreach (var line in text.Split('\n'))
        {
            var l = line.Trim();
            if (l.StartsWith("## "))
                sb.Append($"<h5 class='fw-bold mt-3 mb-2'>{l[3..]}</h5>");
            else if (l.StartsWith("# "))
                sb.Append($"<h4 class='fw-bold mt-3 mb-2'>{l[2..]}</h4>");
            else if (l.StartsWith("- "))
                sb.Append($"<li>{System.Text.RegularExpressions.Regex.Replace(l[2..], @"\*\*(.+?)\*\*", "<strong>$1</strong>")}</li>");
            else if (!string.IsNullOrWhiteSpace(l))
                sb.Append($"<p>{System.Text.RegularExpressions.Regex.Replace(l, @"\*\*(.+?)\*\*", "<strong>$1</strong>")}</p>");
        }
        sb.Append("</div>");
        return sb.ToString();
    }
}

<h3 class="mb-4">✅ AI Tahlil Natijasi — @bodyPart</h3>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger"><strong>⚠️ Xatolik:</strong> @error</div>
}

@if (success && !string.IsNullOrEmpty(analysis))
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold bg-success text-white">✅ AI Tahlil Natijasi</div>
                <div class="card-body">
                    @Html.Raw(FormatMarkdown(analysis))
                </div>
                <div class="card-footer bg-light">
                    <button class="btn btn-outline-primary btn-sm" onclick="copyResult()">📋 Nusxa olish</button>
                    <a href="/AIAnalysis" class="btn btn-outline-secondary btn-sm ms-2">🔄 Yangi tahlil</a>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm border-primary">
                <div class="card-header bg-primary bg-opacity-10 fw-semibold">💾 Protokolga saqlash</div>
                <div class="card-body">
                    <form method="post" asp-controller="AIAnalysis" asp-action="SaveToProtocol">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="analysisResult" value="@analysis" />
                        <div class="mb-3">
                            <label class="form-label">Protokol ID</label>
                            <input name="protocolId" class="form-control" placeholder="Protokol GUID..." required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">💾 Saqlash</button>
                    </form>
                </div>
            </div>

            <div class="alert alert-warning mt-3 small">
                <strong>⚠️ Muhim:</strong> Bu AI tomonidan berilgan dastlabki tahlil.
                Yakuniy tashxis faqat malakali shifokor tomonidan qo'yiladi.
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
function copyResult() {
    var text = document.querySelector('.ai-content')?.innerText ?? '';
    navigator.clipboard.writeText(text).then(function() {
        alert('Natija nusxalandi!');
    });
}
</script>
}
