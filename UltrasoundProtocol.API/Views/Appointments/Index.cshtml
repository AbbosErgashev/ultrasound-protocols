@model IEnumerable<AppointmentDto>
@{
    ViewData["Title"] = "Randevular";
    var patients = (IEnumerable<PatientDto>)ViewBag.Patients;
    var doctorUsername = ViewBag.DoctorUsername as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>📅 Qabullar</h3>
    <button class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#createForm">+ Yangi randevu</button>
</div>

<div class="collapse mb-4" id="createForm">
    <div class="card border-primary">
        <div class="card-body">
            <form method="post" asp-controller="Appointments" asp-action="Create">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DoctorUsername" value="@doctorUsername" />
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Bemor</label>
                        <select name="PatientId" class="form-select" required>
                            <option value="">Tanlang...</option>
                            @foreach (var p in patients)
                            {
                                <option value="@p.Id">@p.FullName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Sana va vaqt</label>
                        <input name="AppointmentDate" type="datetime-local" class="form-control"
                               value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Izoh</label>
                        <input name="Notes" class="form-control" placeholder="Izoh..." />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-success w-100">💾 Saqlash</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Bemor</th>
                    <th>Sana</th>
                    <th>Shifokor</th>
                    <th>Izoh</th>
                    <th>Holat</th>
                    <th>Amallar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.OrderByDescending(x => x.AppointmentDate))
                {
                    <tr>
                        <td>@a.PatientName</td>
                        <td>@a.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@a.DoctorUsername</td>
                        <td>@(a.Notes ?? "—")</td>
                        <td>
                            @if (a.IsCancelled)
                            { <span class="badge bg-danger">Bekor qilingan</span> }
                            else if (a.IsConfirmed)
                            { <span class="badge bg-success">Tasdiqlangan</span> }
                            else
                            { <span class="badge bg-warning">Kutilmoqda</span> }
                        </td>
                        <td>
                            @if (!a.IsConfirmed && !a.IsCancelled)
                            {
                                <form method="post" asp-controller="Appointments" asp-action="Confirm"
                                      asp-route-id="@a.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-success me-1">✓</button>
                                </form>
                                <form method="post" asp-controller="Appointments" asp-action="Cancel"
                                      asp-route-id="@a.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">✗</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
