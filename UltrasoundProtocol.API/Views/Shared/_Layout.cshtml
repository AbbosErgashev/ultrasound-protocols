<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MedUZI</title>
    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
    <script>
        (function () {
            try {
                var theme = localStorage.getItem('meduzi-theme') === 'dark' ? 'dark' : 'light';
                document.documentElement.setAttribute('data-theme', theme);
            } catch (_) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
    <link rel="stylesheet" href="/app.css?v=20260525-3" />
    <style>
        body { display: flex; min-height: 100vh; background: var(--app-bg); color: var(--app-text); overflow-x: hidden; }
        .sidebar { width: 260px; min-width: 260px; min-height: 100vh; background: var(--app-sidebar-bg); color: #fff; flex-shrink: 0; display: flex; flex-direction: column; overflow: hidden; transition: width 0.18s ease, min-width 0.18s ease, transform 0.18s ease, opacity 0.14s ease; }
        .sidebar-brand, .sidebar nav { width: 260px; flex-shrink: 0; }
        .sidebar-brand { padding: 1.2rem 1.5rem; font-size: 1.1rem; font-weight: 700; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar .nav-link { color: rgba(255,255,255,0.8); padding: 0.6rem 1.5rem; border-radius: 0; transition: background 0.15s; display: flex; align-items: center; gap: 0.5rem; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: rgba(255,255,255,0.12); color: #fff; }
        .sidebar .nav-section { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.45); padding: 1rem 1.5rem 0.3rem; }
        body.sidebar-collapsed .sidebar { width: 0; min-width: 0; transform: translateX(-100%); opacity: 0; pointer-events: none; }
        .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .topbar { background: var(--app-surface); border-bottom: 1px solid var(--app-border); padding: 0.75rem 1.5rem; display: flex; align-items: center; justify-content: space-between; }
        .topbar-left { display: flex; align-items: center; gap: 0.75rem; min-width: 0; }
        .topbar-title { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .sidebar-toggle { width: 38px; height: 34px; border: 1px solid var(--app-border); border-radius: 8px; background: var(--app-surface); color: var(--app-text); display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; cursor: pointer; transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease; }
        .sidebar-toggle:hover { border-color: #38bdf8; box-shadow: 0 0 0 0.15rem rgba(56,189,248,0.16); }
        .sidebar-toggle:focus-visible { outline: 2px solid var(--app-focus-ring); outline-offset: 2px; }
        .sidebar-toggle-icon { width: 18px; height: 14px; position: relative; display: block; }
        .sidebar-toggle-icon span { position: absolute; left: 0; width: 18px; height: 2px; border-radius: 999px; background: currentColor; transition: transform 0.18s ease, width 0.18s ease, left 0.18s ease; }
        .sidebar-toggle-icon span:nth-child(1) { top: 0; }
        .sidebar-toggle-icon span:nth-child(2) { top: 6px; }
        .sidebar-toggle-icon span:nth-child(3) { top: 12px; }
        body.sidebar-collapsed .sidebar-toggle-icon span:nth-child(1) { width: 10px; left: 7px; transform: translateY(2px) rotate(35deg); }
        body.sidebar-collapsed .sidebar-toggle-icon span:nth-child(3) { width: 10px; left: 7px; transform: translateY(-2px) rotate(-35deg); }
        .page-body { flex: 1; padding: 1.5rem; overflow-y: auto; }
        .role-badge { font-size: 0.7rem; padding: 2px 8px; border-radius: 20px; }
    </style>
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="sidebar">
        <div class="sidebar-brand">🏥 MedUZI</div>
        <nav class="nav flex-column pt-2">
            <a class="nav-link" href="/Dashboard">📊 Boshqaruv paneli</a>

            @if (User.IsInRole("Doctor") || User.IsInRole("SeniorDoctor") || User.IsInRole("ChiefDoctor"))
            {
                <div class="nav-section">Klinik</div>
                <a class="nav-link" href="/Patients">👥 Bemorlar</a>
                <a class="nav-link" href="/Protocols">📋 Protokollar</a>
                <a class="nav-link" href="/Protocols/Create">➕ Yangi protokol</a>
                <a class="nav-link" href="/Appointments">📅 Qabullar</a>
            }

            @if (User.IsInRole("User"))
            {
                <a class="nav-link" href="/MyDiagnoses">🩺 Mening tashxislarim</a>
            }

            @if (User.IsInRole("SeniorDoctor") || User.IsInRole("ChiefDoctor"))
            {
                <div class="nav-section">Hisobot</div>
                <a class="nav-link" href="/Statistics">📈 Statistika</a>
            }

            @if (User.IsInRole("ChiefDoctor"))
            {
                <a class="nav-link" href="/AuditLogs">🔍 Audit loglar</a>
            }

            @if (User.IsInRole("ContentManager") || User.IsInRole("ChiefDoctor"))
            {
                <div class="nav-section">Kontent</div>
                <a class="nav-link" href="/Manage/News">📰 Yangiliklar</a>
                <a class="nav-link" href="/Manage/Services">🩺 Xizmatlar</a>
                <a class="nav-link" href="/Manage/Doctors">👨‍⚕️ Shifokorlar</a>
            }

            <div class="nav-section">Hisob</div>
            <a class="nav-link" href="/Profile">👤 Profil</a>
        </nav>
    </div>
    <div class="main-content">
        <div class="topbar">
            <div class="topbar-left">
                <button type="button" class="sidebar-toggle" data-sidebar-toggle aria-label="Menyuni yashirish" title="Menyuni yashirish" aria-expanded="true">
                    <span class="sidebar-toggle-icon" aria-hidden="true">
                        <span></span>
                        <span></span>
                        <span></span>
                    </span>
                </button>
                <span class="fw-semibold text-muted topbar-title">@ViewData["Title"]</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                @{
                    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
                    var roleColor = role switch {
                        "ChiefDoctor" => "bg-danger",
                        "SeniorDoctor" => "bg-warning text-dark",
                        "Doctor" => "bg-primary",
                        "ContentManager" => "bg-success",
                        _ => "bg-secondary"
                    };
                }
                @* <span class="badge @roleColor role-badge">@role</span> *@
                <button type="button" class="theme-toggle" data-theme-toggle aria-label="Tun rejimini yoqish" title="Tun rejimini yoqish">
                    <span data-theme-toggle-icon aria-hidden="true">&#9728;</span>
                </button>
                <span class="text-dark fw-semibold small">@User.Identity!.Name</span>
                <a href="/Auth/Logout" class="btn btn-sm btn-outline-danger">Chiqish</a>
            </div>
        </div>
        <div class="page-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="/site.js?v=20260525-2"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
