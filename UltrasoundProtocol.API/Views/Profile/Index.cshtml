@{
    ViewData["Title"] = "Mening profilim";
    var userId = User.FindFirst("UserId")?.Value;
    var fullNameValue = ViewBag.FullName as string;
    var usernameValue = ViewBag.Username as string;
    var roleValue = ViewBag.Role as string;
    var fullName = string.IsNullOrWhiteSpace(fullNameValue) ? "Kiritilmagan" : fullNameValue;
    var username = string.IsNullOrWhiteSpace(usernameValue) ? "Kiritilmagan" : usernameValue;
    var role = string.IsNullOrWhiteSpace(roleValue) ? "User" : roleValue;
}

<section class="profile-page">
    <div class="profile-card">
        <div class="profile-header">
            <div class="profile-avatar">
                @username.ToString().Substring(0, 1).ToUpperInvariant()
            </div>
            <div>
                <span class="profile-kicker">Shaxsiy ma'lumotlar</span>
                <h2>@fullName</h2>
                <p>@username</p>
            </div>
        </div>

        <div class="profile-info-grid">
            <div class="profile-info-row">
                <span>F.I.Sh</span>
                <strong>@fullName</strong>
            </div>
            <div class="profile-info-row">
                <span>Login</span>
                <strong>@username</strong>
            </div>
            <div class="profile-info-row">
                <span>Rol</span>
                <strong>@role</strong>
            </div>
            <div class="profile-info-row">
                <span>Foydalanuvchi ID</span>
                <strong>@(string.IsNullOrEmpty(userId) ? "Statik foydalanuvchi" : userId)</strong>
            </div>
        </div>

        <div class="profile-actions">
            <a href="/Auth/Logout" class="btn btn-outline-danger w-100">Tizimdan chiqish</a>
        </div>
    </div>
</section>
