@{
    ViewData["Title"] = "Kontent boshqaruv paneli";
    var fullName = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? User.Identity?.Name;

    var allNews = (IEnumerable<NewsArticleDto>)ViewBag.News;
    var allServices = (IEnumerable<ServiceItemDto>)ViewBag.Services;
    var allDoctors = (IEnumerable<DoctorProfileDto>)ViewBag.Doctors;

    int totalNews = allNews.Count();
    int publishedNews = allNews.Count(n => n.IsPublished);
    int totalServices = allServices.Count();
    int activeServices = allServices.Count(s => s.IsActive);
    int totalDoctors = allDoctors.Count();
    int activeDoctors = allDoctors.Count(d => d.IsActive);
    var recentNews = allNews.OrderByDescending(n => n.CreatedAt).Take(5);
}

<div class="mb-4">
    <h3>📝 Kontent boshqaruv paneli</h3>
    <p class="text-muted">Xush kelibsiz, <strong>@fullName</strong>!</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;">
            <div class="card-body text-center py-4">
                <div style="font-size:2.5rem;">📰</div>
                <h2 class="fw-bold mb-0">@totalNews</h2>
                <small>Yangiliklar</small>
                <div class="mt-2">
                    <span class="badge bg-light text-dark">@publishedNews chop etilgan</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="background:linear-gradient(135deg,#11998e,#38ef7d);color:#fff;">
            <div class="card-body text-center py-4">
                <div style="font-size:2.5rem;">🩺</div>
                <h2 class="fw-bold mb-0">@totalServices</h2>
                <small>Xizmatlar</small>
                <div class="mt-2">
                    <span class="badge bg-light text-dark">@activeServices faol</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="background:linear-gradient(135deg,#ee9ca7,#ffdde1);color:#333;">
            <div class="card-body text-center py-4">
                <div style="font-size:2.5rem;">👨‍⚕️</div>
                <h2 class="fw-bold mb-0">@totalDoctors</h2>
                <small>Shifokorlar</small>
                <div class="mt-2">
                    <span class="badge bg-dark text-light">@activeDoctors faol</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12"><h5 class="fw-semibold">⚡ Tezkor harakatlar</h5></div>
    <div class="col-md-4">
        <a href="/Manage/News" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div style="width:50px;height:50px;border-radius:12px;background:#e8eaf6;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">📰</div>
                <div>
                    <h6 class="mb-0 text-dark">Yangilik qo'shish</h6>
                    <small class="text-muted">Yangilik yozing va chop eting</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Manage/Services" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div style="width:50px;height:50px;border-radius:12px;background:#e8f5e9;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">🩺</div>
                <div>
                    <h6 class="mb-0 text-dark">Xizmat boshqarish</h6>
                    <small class="text-muted">Xizmatlar narxini yangilang</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Manage/Doctors" class="card border-0 shadow-sm text-decoration-none h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div style="width:50px;height:50px;border-radius:12px;background:#fce4ec;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">👨‍⚕️</div>
                <div>
                    <h6 class="mb-0 text-dark">Shifokor tahrirlash</h6>
                    <small class="text-muted">Shifokorlar profilini yangilang</small>
                </div>
            </div>
        </a>
    </div>
</div>

@if (recentNews.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-semibold">📋 Oxirgi yangiliklar</div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Sarlavha</th><th>Sana</th><th>Holat</th></tr>
                </thead>
                <tbody>
                    @foreach (var n in recentNews)
                    {
                        <tr>
                            <td>@n.Title</td>
                            <td>@n.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td>
                                <span class="badge @(n.IsPublished ? "bg-success" : "bg-secondary")">
                                    @(n.IsPublished ? "Chop etilgan" : "Qoralama")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
