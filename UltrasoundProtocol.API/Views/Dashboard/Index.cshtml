@model DashboardDto
@{
    ViewData["Title"] = "Boshqaruv paneli";
    var fullName = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? User.Identity?.Name;
    var services = ((IEnumerable<ServiceItemDto>?)ViewBag.Services)?.ToList() ?? new List<ServiceItemDto>();
}

@functions {
    static bool IsImageUrl(string? value) =>
        Uri.TryCreate(value?.Trim(), UriKind.Absolute, out var uri) &&
        (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);

    static bool IsBreastService(string name)
    {
        var normalized = name
            .Replace("'", string.Empty)
            .Replace("`", string.Empty)
            .Replace("‘", string.Empty)
            .Replace("’", string.Empty)
            .Replace("ʻ", string.Empty);

        return normalized.Contains("Sut bez", StringComparison.OrdinalIgnoreCase) ||
            normalized.Contains("Kokrak bez", StringComparison.OrdinalIgnoreCase) ||
            normalized.Contains("Кукрак без", StringComparison.OrdinalIgnoreCase) ||
            normalized.Contains("Кўкрак без", StringComparison.OrdinalIgnoreCase);
    }

    static string DisplayServiceName(ServiceItemDto service) =>
        IsBreastService(service.Name)
            ? "Sut bezlari"
            : service.Name;
}

<h3 class="mb-2">📊 Boshqaruv paneli</h3>
<p class="text-muted mb-4">Xush kelibsiz, <strong>@fullName</strong>!</p>

<div class="row g-4 mb-4">
    <div class="col-md-4 col-lg-2">
        <div class="card text-bg-primary h-100">
            <div class="card-body text-center">
                <h2 class="fw-bold">@Model.TotalPatients</h2>
                <small>Bemorlar</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card text-bg-success h-100">
            <div class="card-body text-center">
                <h2 class="fw-bold">@Model.TotalProtocols</h2>
                <small>Protokollar</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card text-bg-info h-100">
            <div class="card-body text-center">
                <h2 class="fw-bold">@Model.ActiveProtocols</h2>
                <small>Faol</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card text-bg-secondary h-100">
            <div class="card-body text-center">
                <h2 class="fw-bold">@Model.CompletedProtocols</h2>
                <small>Yakunlangan</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card text-bg-warning h-100">
            <div class="card-body text-center">
                <h2 class="fw-bold">@Model.TodayAppointments</h2>
                <small>Bugungi randevular</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card text-bg-danger h-100">
            <div class="card-body text-center">
                <h2 class="fw-bold">@Model.UnreadNotifications</h2>
                <small>Xabarlar</small>
            </div>
        </div>
    </div>
</div>

@if (services.Any())
{
    <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
        <h5 class="mb-0">Yangi protokol</h5>
        <a href="/Protocols/Create" class="btn btn-sm btn-outline-primary">Barchasi</a>
    </div>
    <div class="row g-3 dashboard-service-grid mb-4">
        @foreach (var service in services)
        {
            var serviceIcon = service.Icon?.Trim();
            var isImageIcon = IsImageUrl(serviceIcon);
            var isBreastService = IsBreastService(service.Name);
            var priceText = service.Price.HasValue ? $"{service.Price.Value:N0} so'm" : null;

            <div class="col-md-6 col-xl-4">
                @if (isBreastService)
                {
                    <a href="/BreastProtocols/Create" class="dashboard-service-card dashboard-service-card-active">
                        <span class="dashboard-service-icon">
                            @if (isImageIcon)
                            {
                                <img src="@serviceIcon" alt="@DisplayServiceName(service)" loading="lazy" />
                            }
                            else
                            {
                                @serviceIcon
                            }
                        </span>
                        <span class="dashboard-service-body">
                            <span class="dashboard-service-name">@DisplayServiceName(service)</span>
                            @if (!string.IsNullOrWhiteSpace(service.Description))
                            {
                                <span class="dashboard-service-description">@service.Description</span>
                            }
                            @if (priceText is not null)
                            {
                                <span class="dashboard-service-price">@priceText</span>
                            }
                        </span>
                    </a>
                }
                else
                {
                    <button type="button" class="dashboard-service-card dashboard-service-card-disabled" disabled>
                        <span class="dashboard-service-icon">
                            @if (isImageIcon)
                            {
                                <img src="@serviceIcon" alt="@DisplayServiceName(service)" loading="lazy" />
                            }
                            else
                            {
                                @serviceIcon
                            }
                        </span>
                        <span class="dashboard-service-body">
                            <span class="dashboard-service-name">@DisplayServiceName(service)</span>
                            @if (!string.IsNullOrWhiteSpace(service.Description))
                            {
                                <span class="dashboard-service-description">@service.Description</span>
                            }
                            @if (priceText is not null)
                            {
                                <span class="dashboard-service-price">@priceText</span>
                            }
                        </span>
                    </button>
                }
            </div>
        }
    </div>
}

@if (Model.MonthlyStats.Count > 0)
{
    <div class="card">
        <div class="card-header fw-semibold">📈 Oxirgi 6 oy statistikasi</div>
        <div class="card-body">
            <table class="table table-sm">
                <thead>
                    <tr><th>Oy</th><th>Protokollar</th><th>Bemorlar</th></tr>
                </thead>
                <tbody>
                    @foreach (var stat in Model.MonthlyStats)
                    {
                        <tr>
                            <td>@stat.Month</td>
                            <td>@stat.ProtocolCount</td>
                            <td>@stat.PatientCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<style>
    .dashboard-service-card {
        width: 100%;
        min-height: 142px;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem;
        border: 1px solid #dbe4ef;
        border-radius: 8px;
        background: #fff;
        color: #0f172a;
        text-align: left;
        text-decoration: none;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
        transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    }

    .dashboard-service-card-active:hover {
        border-color: #2563eb;
        box-shadow: 0 12px 28px rgba(37, 99, 235, 0.14);
        color: #0f172a;
        transform: translateY(-1px);
    }

    .dashboard-service-card-disabled {
        cursor: default;
        opacity: 0.72;
    }

    .dashboard-service-icon {
        width: 50px;
        height: 50px;
        flex: 0 0 50px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background: #eef6ff;
        color: #1d4ed8;
        font-size: 1.5rem;
        overflow: hidden;
    }

    .dashboard-service-icon img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .dashboard-service-body {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .dashboard-service-name {
        font-weight: 700;
        line-height: 1.25;
    }

    .dashboard-service-description {
        color: #64748b;
        font-size: 0.88rem;
        line-height: 1.4;
    }

    .dashboard-service-price {
        width: fit-content;
        margin-top: 0.1rem;
        padding: 0.18rem 0.5rem;
        border-radius: 999px;
        background: #ecfdf5;
        color: #047857;
        font-size: 0.78rem;
        font-weight: 700;
    }

    @@media (max-width: 575.98px) {
        .dashboard-service-card {
            min-height: auto;
        }
    }
</style>
