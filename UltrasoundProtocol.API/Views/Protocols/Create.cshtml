@model IEnumerable<ServiceItemDto>
@{
    ViewData["Title"] = "Yangi protokol";
    var services = Model?.ToList() ?? new List<ServiceItemDto>();
}

@functions {
    static bool IsImageUrl(string? value) =>
        Uri.TryCreate(value?.Trim(), UriKind.Absolute, out var uri) &&
        (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);

    static bool IsBreastService(string name)
    {
        var normalized = name
            .Replace("'", string.Empty)
            .Replace("`", string.Empty)
            .Replace("‘", string.Empty)
            .Replace("’", string.Empty)
            .Replace("ʻ", string.Empty);

        return normalized.Contains("Sut bez", StringComparison.OrdinalIgnoreCase) ||
            normalized.Contains("Kokrak bez", StringComparison.OrdinalIgnoreCase) ||
            normalized.Contains("Кукрак без", StringComparison.OrdinalIgnoreCase) ||
            normalized.Contains("Кўкрак без", StringComparison.OrdinalIgnoreCase);
    }

    static string DisplayServiceName(ServiceItemDto service) =>
        IsBreastService(service.Name)
            ? "Sut bezlari"
            : service.Name;
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h3 class="mb-1">Yangi protokol</h3>
        <div class="text-muted">Aktiv xizmatlardan protokol turini tanlang.</div>
    </div>
    <a href="/Protocols" class="btn btn-outline-secondary">Protokollar ro'yxati</a>
</div>

@if (!services.Any())
{
    <div class="alert alert-info">Aktiv xizmatlar topilmadi.</div>
}
else
{
    <div class="row g-3 protocol-service-grid">
        @foreach (var service in services)
        {
            var serviceIcon = service.Icon?.Trim();
            var isImageIcon = IsImageUrl(serviceIcon);
            var isBreastService = IsBreastService(service.Name);
            var priceText = service.Price.HasValue ? $"{service.Price.Value:N0} so'm" : null;

            <div class="col-md-6 col-xl-4">
                @if (isBreastService)
                {
                    <a href="/BreastProtocols/Create" class="protocol-service-card protocol-service-card-active">
                        <span class="protocol-service-icon">
                            @if (isImageIcon)
                            {
                                <img src="@serviceIcon" alt="@DisplayServiceName(service)" loading="lazy" />
                            }
                            else
                            {
                                @serviceIcon
                            }
                        </span>
                        <span class="protocol-service-body">
                            <span class="protocol-service-name">@DisplayServiceName(service)</span>
                            @if (!string.IsNullOrWhiteSpace(service.Description))
                            {
                                <span class="protocol-service-description">@service.Description</span>
                            }
                            @if (priceText is not null)
                            {
                                <span class="protocol-service-price">@priceText</span>
                            }
                        </span>
                    </a>
                }
                else
                {
                    <button type="button" class="protocol-service-card protocol-service-card-disabled" disabled>
                        <span class="protocol-service-icon">
                            @if (isImageIcon)
                            {
                                <img src="@serviceIcon" alt="@DisplayServiceName(service)" loading="lazy" />
                            }
                            else
                            {
                                @serviceIcon
                            }
                        </span>
                        <span class="protocol-service-body">
                            <span class="protocol-service-name">@DisplayServiceName(service)</span>
                            @if (!string.IsNullOrWhiteSpace(service.Description))
                            {
                                <span class="protocol-service-description">@service.Description</span>
                            }
                            @if (priceText is not null)
                            {
                                <span class="protocol-service-price">@priceText</span>
                            }
                        </span>
                    </button>
                }
            </div>
        }
    </div>
}

<style>
    .protocol-service-card {
        width: 100%;
        min-height: 150px;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1.1rem;
        border: 1px solid #dbe4ef;
        border-radius: 8px;
        background: #fff;
        color: #0f172a;
        text-align: left;
        text-decoration: none;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
        transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    }

    .protocol-service-card-active:hover {
        border-color: #2563eb;
        box-shadow: 0 12px 28px rgba(37, 99, 235, 0.14);
        color: #0f172a;
        transform: translateY(-1px);
    }

    .protocol-service-card-disabled {
        cursor: default;
        opacity: 0.72;
    }

    .protocol-service-icon {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background: #eef6ff;
        color: #1d4ed8;
        font-size: 1.6rem;
        overflow: hidden;
    }

    .protocol-service-icon img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .protocol-service-body {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .protocol-service-name {
        font-weight: 700;
        line-height: 1.25;
    }

    .protocol-service-description {
        color: #64748b;
        font-size: 0.9rem;
        line-height: 1.45;
    }

    .protocol-service-price {
        width: fit-content;
        margin-top: 0.15rem;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        background: #ecfdf5;
        color: #047857;
        font-size: 0.8rem;
        font-weight: 700;
    }

    @@media (max-width: 575.98px) {
        .protocol-service-card {
            min-height: auto;
        }
    }
</style>
