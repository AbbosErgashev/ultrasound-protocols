@model IEnumerable<ProtocolDto>
@{
    ViewData["Title"] = "UZI Protokollar";
    string? search = ViewBag.Search;
    string? status = ViewBag.Status;
}

@functions {
    static string GetStatusBadge(ProtocolStatus s) => s switch {
        ProtocolStatus.Draft => "bg-secondary",
        ProtocolStatus.Active => "bg-primary",
        ProtocolStatus.Completed => "bg-success",
        ProtocolStatus.Archived => "bg-dark",
        _ => "bg-light text-dark"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>📋 UZI Protokollar</h3>
    <div class="d-flex gap-2">
        <a href="/Protocols/ExportExcel" class="btn btn-success btn-sm">📊 Excel</a>
        <a href="/Protocols/Create" class="btn btn-primary">+ Yangi protokol</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" asp-controller="Protocols" asp-action="Index">
            <div class="row g-2 align-items-center">
                <div class="col-md-4">
                    <input name="search" value="@search" class="form-control form-control-sm"
                           placeholder="🔍 Bemor, organ qidiring..." />
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select form-select-sm">
                        <option value="">Barchasi</option>
                        <option value="Draft" selected="@(status=="Draft")">Qoralama</option>
                        <option value="Active" selected="@(status=="Active")">Faol</option>
                        <option value="Completed" selected="@(status=="Completed")">Yakunlangan</option>
                        <option value="Archived" selected="@(status=="Archived")">Arxivlangan</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-sm btn-outline-primary">Qidirish</button>
                </div>
                <div class="col-md-3">
                    <span class="text-muted small">@Model.Count() ta natija</span>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Natija topilmadi.</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Bemor</th>
                        <th>Organ</th>
                        <th>Sana</th>
                        <th>Shifokor</th>
                        <th>Holat</th>
                        <th>AI</th>
                        <th>Amallar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.PatientName</td>
                            <td><strong>@p.BodyPart</strong></td>
                            <td>@p.ExamDate.ToString("dd.MM.yyyy")</td>
                            <td>@p.DoctorUsername</td>
                            <td><span class="badge @GetStatusBadge(p.Status)">@p.Status</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(p.AIAnalysisResult))
                                { <span class="badge bg-info">✓</span> }
                                else
                                { <span class="text-muted">—</span> }
                            </td>
                            <td class="d-flex gap-1">
                                <a href="/Protocols/ExportPdf/@p.Id" class="btn btn-sm btn-outline-danger" title="PDF">📄</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
