@model PatientCreateDto
@{
    ViewData["Title"] = "Yangi bemor qo'shish";
}

<h3 class="mb-4">➕ Yangi bemor qo'shish</h3>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <form method="post" asp-controller="Patients" asp-action="Create">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">To'liq ism</label>
                <input name="FullName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Tug'ilgan sana</label>
                <input name="DateOfBirth" type="date" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Jins</label>
                <select name="Gender" class="form-select" required>
                    <option value="">Tanlang...</option>
                    <option value="Erkak">Erkak</option>
                    <option value="Ayol">Ayol</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Telefon raqam</label>
                <input name="PhoneNumber" class="form-control" placeholder="+998901234567" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Email (ixtiyoriy)</label>
                <input name="Email" type="email" class="form-control" />
            </div>
            <hr />
            <h6 class="fw-bold text-primary">🔐 Tizimga kirish ma'lumotlari</h6>
            <p class="text-muted small">Bemor ushbu login va parol bilan tizimga kirib natijalarini ko'ra oladi</p>
            <div class="mb-3">
                <label class="form-label">Login (username)</label>
                <input name="Username" class="form-control" placeholder="masalan: bemor001" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Parol</label>
                <input name="Password" type="password" class="form-control" required />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">💾 Saqlash</button>
                <a href="/Patients" class="btn btn-outline-secondary">Bekor qilish</a>
            </div>
        </form>
    </div>
</div>
