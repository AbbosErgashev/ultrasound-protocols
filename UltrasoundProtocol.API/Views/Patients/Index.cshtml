@model IEnumerable<PatientDto>
@{
    ViewData["Title"] = "Bemorlar ro'yxati";
    string? search = ViewBag.Search;
    string? gender = ViewBag.Gender;
    string? status = ViewBag.Status;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>👥 Bemorlar ro'yxati</h3>
    <div class="d-flex gap-2">
        <a href="/Patients/ExportExcel" class="btn btn-success btn-sm">📊 Excel</a>
        <a href="/Patients/Create" class="btn btn-primary">+ Yangi bemor</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" asp-controller="Patients" asp-action="Index">
            <div class="row g-2 align-items-center">
                <div class="col-md-4">
                    <input name="search" value="@search" class="form-control form-control-sm"
                           placeholder="Ism, login, telefon qidiring..." />
                </div>
                <div class="col-md-2">
                    <select name="gender" class="form-select form-select-sm">
                        <option value="">Jinsi: barchasi</option>
                        <option value="Erkak" selected="@(gender=="Erkak")">Erkak</option>
                        <option value="Ayol" selected="@(gender=="Ayol")">Ayol</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="status" class="form-select form-select-sm">
                        <option value="">Holat: barchasi</option>
                        <option value="Active" selected="@(status=="Active")">Faol</option>
                        <option value="Inactive" selected="@(status=="Inactive")">Nofaol</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-sm btn-outline-primary">Qidirish</button>
                        <a asp-controller="Patients" asp-action="Index" class="btn btn-sm btn-outline-secondary">Filtrlarni tozalash</a>
                    </div>
                </div>
                <div class="col-md-1">
                    <span class="text-muted small">@Model.Count() ta natija</span>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Natija topilmadi.</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ism</th>
                        <th>Login</th>
                        <th>Telefon</th>
                        <th>Jins</th>
                        <th>Tug'ilgan</th>
                        <th>Qo'shilgan</th>
                        <th>Holat</th>
                        @if (User.IsInRole("ChiefDoctor"))
                        {
                            <th>🔐 Amallar</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td><strong>@p.FullName</strong></td>
                            <td><code>@p.Username</code></td>
                            <td>@p.PhoneNumber</td>
                            <td>@p.Gender</td>
                            <td>@p.DateOfBirth.ToString("dd.MM.yyyy")</td>
                            <td>@p.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")">
                                    @(p.IsActive ? "Faol" : "Nofaol")
                                </span>
                            </td>
                            @if (User.IsInRole("ChiefDoctor"))
                            {
                                <td>
                                    <button class="btn btn-sm btn-outline-warning"
                                            data-bs-toggle="modal" data-bs-target="#credModal"
                                            data-pid="@p.Id"
                                            data-pname="@p.FullName"
                                            data-pusername="@p.Username">
                                        🔑 Login/Parol
                                    </button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (User.IsInRole("ChiefDoctor"))
{
    <div class="modal fade" id="credModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-warning bg-opacity-25">
                    <h5 class="modal-title">🔐 Login/Parol o'zgartirish</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-controller="Patients" asp-action="ChangeCredentials">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="credPatientId" />
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="gender" value="@gender" />
                    <input type="hidden" name="status" value="@status" />
                    <div class="modal-body">
                        <p>Bemor: <strong id="credPatientName"></strong></p>
                        <div class="mb-3">
                            <label class="form-label">Yangi Login</label>
                            <input name="newUsername" id="credUsername" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Yangi Parol</label>
                            <input name="newPassword" type="password" class="form-control" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Yopish</button>
                        <button type="submit" class="btn btn-warning">💾 Saqlash</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('credModal')?.addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('credPatientId').value = btn.dataset.pid;
            document.getElementById('credPatientName').textContent = btn.dataset.pname;
            document.getElementById('credUsername').placeholder = 'Joriy: ' + btn.dataset.pusername;
        });
    </script>
}
