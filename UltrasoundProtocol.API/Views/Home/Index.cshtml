                <a href="/Auth/Login" class="btn btn-outline-light btn-sm">🔐 Tizimga kirish</a>
            </div>
        </div>
        <hr class="border-secondary my-4" />
        <div class="text-center">
            <span class="text-white-50 small">© @DateTime.Today.Year MedUZI Diagnostika Markazi. Barcha huquqlar himoyalangan.</span>
        </div>
