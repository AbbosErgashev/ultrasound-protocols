            </div>
            <div class="col-md-4">
                <h6 class="fw-bold mb-3">Tezkor havolalar</h6>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="#xizmatlar" class="footer-link">🩺 Xizmatlar</a></li>
                    <li class="mb-2"><a href="#shifokorlar" class="footer-link">👨‍⚕️ Shifokorlar</a></li>
                    <li class="mb-2"><a href="#yangiliklar" class="footer-link">📰 Yangiliklar</a></li>
                    <li class="mb-2"><a href="#aloqa" class="footer-link">📞 Aloqa</a></li>
                </ul>
            </div>
