        </button>
        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav ms-auto me-3">
                <li class="nav-item"><a class="nav-link" href="#xizmatlar">Xizmatlar</a></li>
                <li class="nav-item"><a class="nav-link" href="#biz-haqimizda">Biz haqimizda</a></li>
                <li class="nav-item"><a class="nav-link" href="#shifokorlar">Shifokorlar</a></li>
                <li class="nav-item"><a class="nav-link" href="#yangiliklar">Yangiliklar</a></li>
                <li class="nav-item"><a class="nav-link" href="#aloqa">Aloqa</a></li>
            </ul>
            <button type="button" class="theme-toggle theme-toggle-nav me-2" data-theme-toggle aria-label="Tun rejimini yoqish" title="Tun rejimini yoqish">
