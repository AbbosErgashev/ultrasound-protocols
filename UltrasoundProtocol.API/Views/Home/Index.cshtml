@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "MedUZI — Zamonaviy Ultratovush Diagnostika Markazi";
    var dbNews = (IEnumerable<NewsArticleDto>)ViewBag.News;
    var dbServices = (IEnumerable<ServiceItemDto>)ViewBag.Services;
    var dbDoctors = (IEnumerable<DoctorProfileDto>)ViewBag.Doctors;
}

@functions {
    static string? NormalizeMediaUrl(string? value)
    {
        var mediaUrl = value?.Trim();
        if (string.IsNullOrWhiteSpace(mediaUrl))
            return null;

        if (Uri.TryCreate(mediaUrl, UriKind.Absolute, out _))
            return mediaUrl;

        mediaUrl = mediaUrl.Replace("\\", "/").TrimStart('/');
        return "/" + mediaUrl;
    }

    static string? ToDisplayMediaUrl(string? value)
    {
        var mediaUrl = NormalizeMediaUrl(value);
        if (string.IsNullOrWhiteSpace(mediaUrl))
            return null;

        if (Uri.TryCreate(mediaUrl, UriKind.Absolute, out _))
            return null;

        return mediaUrl;
    }

    static bool IsImageUrl(string? value) =>
        Uri.TryCreate(value?.Trim(), UriKind.Absolute, out var uri) &&
        (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
}

@* ========== NAVBAR ========== *@
